ANTHROPIC_API_KEY=sk-ant-...

# Optional: only needed if fetching directly from Apify.
APIFY_API_TOKEN=

# One Apify dataset id per market — the env var name is APIFY_DATASET_ID_<MARKET>
# in upper case. Add more here as you add markets in config.MARKETS.
APIFY_DATASET_ID_GERMANY=
APIFY_DATASET_ID_BELGIUM=
