ANTHROPIC_API_KEY=sk-ant-...

# Apify auth — used for both triggering actor runs and fetching datasets.
APIFY_TOKEN=

# Optional: skip the actor run and reuse an existing dataset id per market.
# Env var name is APIFY_DATASET_ID_<MARKET> in upper case.
APIFY_DATASET_ID_GERMANY=
APIFY_DATASET_ID_BELGIUM=
